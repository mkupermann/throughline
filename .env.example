# =============================================================================
# Claude Memory — Environment Variables
# =============================================================================
# Copy this file to .env and adjust the values for your setup.
# .env is in .gitignore and will never be committed.
#
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
PGUSER=$USER
PGHOST=localhost
PGPORT=5432
PGDATABASE=claude_memory

# ---------------------------------------------------------------------------
# Optional: OpenAI for embeddings
# Used by scripts/embed.py when Ollama is not available.
# Leave commented out if you are using a local Ollama model instead.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Optional: Anthropic API for memory extraction
# Used by scripts/extract_memory.py when running outside Claude Code CLI.
# Leave commented out if you are running extraction via the Claude CLI
# (Max Plan) — that route has no additional cost.
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Optional: Ollama (local embeddings, no API key required)
# ---------------------------------------------------------------------------
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
